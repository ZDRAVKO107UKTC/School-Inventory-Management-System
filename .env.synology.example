# Synology / Docker deployment settings
# Copy this file to .env next to compose.synology.yml before creating the project.

APP_PORT=8080

POSTGRES_DB=postgres
POSTGRES_USER=school_inventory
POSTGRES_PASSWORD=123456

JWT_SECRET=change_this_to_a_long_random_secret_at_least_32_chars

# Replace with your actual NAS hostname, reverse proxy hostname, or local IP.
FRONTEND_URL=http://185.230.6.51:8088
ALLOWED_ORIGINS=http://185.230.6.51::8088
PASSWORD_RESET_URL=http://185.230.6.51::8088/reset-password

# Set these to true when you place the app behind Synology HTTPS reverse proxy.
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
TRUST_PROXY=false

# Local Synology Postgres usually does not use SSL/TLS.
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=false

# Seed demo data on first startup.
RUN_DB_SEED=true
ENABLE_BACKGROUND_JOBS=true

EMAIL_ENABLED=true
