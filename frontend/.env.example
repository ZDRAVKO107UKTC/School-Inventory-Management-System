# API Configuration
# Preferred API base used by frontend service client
VITE_API_BASE_URL=/api
# Optional legacy proxy target for Vite dev server
VITE_API_URL=http://127.0.0.1:5000
VITE_API_TIMEOUT=30000

# OAuth Configuration
VITE_GOOGLE_REDIRECT_URI=https://shaved-echo-rebates-handmade.trycloudflare.com/auth/callback/google
VITE_TELEGRAM_REDIRECT_URI=https://shaved-echo-rebates-handmade.trycloudflare.com/auth/callback/telegram

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_QR_SCANNER=true

# Environment
VITE_DEBUG_MODE=false
