              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Equipment is under maintenance\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/request/:id/reject",
              "host": ["{{baseUrl}}"],
              "path": ["request", ":id", "reject"]
            }
          }
        },
        {
          "name": "Return Request",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
