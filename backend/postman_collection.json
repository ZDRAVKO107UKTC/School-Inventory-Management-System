{
  "info": {
    "name": "School Inventory Management API",
    "description": "Postman collection aligned with the current backend routes and payloads.\n\nAuthentication note:\n- /auth/login returns the access token in JSON and sets the refresh token as an httpOnly cookie.\n- In Postman, keep the cookie jar enabled for /auth/refresh and /auth/logout to work without manually pasting a refresh token.\n- The refreshToken body field is optional fallback input when you already have the token value from another client.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "refreshToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "equipmentId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "requestId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "1",
      "type": "string"
    }
  ],
