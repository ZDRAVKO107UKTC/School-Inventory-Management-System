    {
      "name": "Requests",
      "item": [
        {
          "name": "Approve Request",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/request/:id/approve",
              "host": ["{{baseUrl}}"],
              "path": ["request", ":id", "approve"]
            }
          }
        },
        {
          "name": "Reject Request",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
