    {
      "name": "Equipment",
      "item": [
        {
          "name": "Get Equipment by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/equipment/1",
              "host": ["{{baseUrl}}"],
              "path": ["equipment", "1"]
            }
          }
        },
        {
          "name": "Get All Equipment",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/equipment",
              "host": ["{{baseUrl}}"],
              "path": ["equipment"]
            }
          }
        },
        {
          "name": "Search Equipment by Name",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/equipment?search=laptop",
              "host": ["{{baseUrl}}"],
              "path": ["equipment"],
              "query": [
                {
                  "key": "search",
                  "value": "laptop"
                }
              ]
            }
          }
        },
        {
          "name": "Filter Equipment by Type",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/equipment?type=Laptop",
              "host": ["{{baseUrl}}"],
              "path": ["equipment"],
              "query": [
                {
                  "key": "type",
                  "value": "Laptop"
                }
              ]
            }
          }
        },
        {
          "name": "Filter by Status (Available)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/equipment?status=available",
              "host": ["{{baseUrl}}"],
              "path": ["equipment"],
              "query": [
                {
                  "key": "status",
                  "value": "available"
                }
              ]
            }
          }
        },
        {
          "name": "Search & Filter Combined",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/equipment?search=mac&status=available&condition=good",
              "host": ["{{baseUrl}}"],
              "path": ["equipment"],
              "query": [
                {
                  "key": "search",
                  "value": "mac"
                },
                {
                  "key": "status",
                  "value": "available"
                },
                {
                  "key": "condition",
                  "value": "good"
                }
              ]
            }
          }
        },
        {
          "name": "Delete Equipment by ID",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/equipment/:id",
              "host": ["{{baseUrl}}"],
              "path": ["equipment", ":id"]
            }
          }
        },
        {
          "name": "Create Equipment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"MacBook Pro\",\n  \"type\": \"Laptop\",\n  \"serial_number\": \"MBP123456\",\n  \"condition\": \"good\",\n  \"status\": \"available\",\n  \"location\": \"Room 101\",\n  \"photo_url\": \"https://example.com/photo.jpg\",\n  \"quantity\": 5\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/equipment",
              "host": ["{{baseUrl}}"],
              "path": ["equipment"]
            }
          }
        },
        {
          "name": "Update Equipment Status",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"checked_out\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/equipment/1/status",
              "host": ["{{baseUrl}}"],
              "path": ["equipment", "1", "status"]
            }
          }
        }
      ]
