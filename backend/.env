# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
DB_USER=postgres
DB_PASSWORD=123456
DB_NAME=school_inventory
DB_HOST=127.0.0.1
DB_PORT=5433

# For production (alternative to individual DB vars)
DATABASE_URL=postgresql://postgres:123456@localhost:5433/school_inventory

# Microservices ports (local)
API_GATEWAY_PORT=5000
AUTH_SERVICE_PORT=5001
USER_SERVICE_PORT=5002
ADMIN_SERVICE_PORT=5003
EQUIPMENT_SERVICE_PORT=5004
REQUEST_SERVICE_PORT=5005
REPORT_SERVICE_PORT=5006
SPATIAL_SERVICE_PORT=5007

# JWT Configuration
JWT_SECRET=super_secret_key_change_this

# Token Expiration (short-lived access token + long-lived refresh token)
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d


EMAIL_ENABLED=true
EMAIL_FROM=school.inventory.bot@gmail.com

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=school.inventory.bot@gmail.com
