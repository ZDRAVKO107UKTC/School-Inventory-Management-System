# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
DB_USER=postgres
DB_PASSWORD=123456
DB_NAME=school_inventory
DB_HOST=127.0.0.1
DB_PORT=5433

# JWT Configuration
JWT_SECRET=change_me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Google OAuth (required for Google login/signup)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/callback/google

# Telegram OAuth (required for Telegram login/signup)
TELEGRAM_BOT_ID=your-telegram-bot-id
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_REDIRECT_URI=http://localhost:5173/auth/callback/telegram
