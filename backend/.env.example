# ============================================================================
# SCHOOL INVENTORY MANAGEMENT SYSTEM (SIMS) - ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your actual values
# ============================================================================

# ============= SERVER =============
# Node environment: development, production, or test
NODE_ENV=development

# Server port
SERVICE_PORT=5000
PORT=5000

# ============= DATABASE =============
# PostgreSQL connection settings
DB_HOST=127.0.0.1
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=123456
DB_NAME=school_inventory
DB_NAME_TEST=school_inventory_test

# Production: use DATABASE_URL instead of individual DB_ vars
# DATABASE_URL=postgresql://user:password@host:port/dbname

# ============= AUTHENTICATION =============
# JWT signing secret (CHANGE IN PRODUCTION - must be extremely strong)
# Min 32 characters, mix of uppercase, lowercase, numbers, symbols
JWT_SECRET=change_me_in_production_use_strong_key

# JWT token expiry times
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ============= CORS =============
# Comma-separated list of allowed origins for frontend requests
# Default supports: localhost frontend dev servers (Vite) and alternative ports
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# ============= LOGGING =============
# Enable detailed database query logging (development only, very verbose)
# Set to 'true' to see all SQL queries with timing - DO NOT use in production
LOG_DB_QUERIES=false

# ============= EMAIL SERVICE =============
# Email configuration for notifications (optional)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password-not-regular-password

# ============= GOOGLE SHEETS INTEGRATION =============
# Google Service Account for backup exports and document storage
# Get credentials from: Google Cloud Console → Service Accounts → Create Key
# Choose JSON format and save the full JSON content below OR as a file

# Option 1: Inline JSON string (works on most platforms)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"..."}

# Option 2: File path to JSON (alternative if inline doesn't work)
# GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service-account-key.json

# Target spreadsheet ID for automatic backups
GOOGLE_SHEETS_BACKUP_ID=your-spreadsheet-id-here

# ============= MICROSERVICES (OPTIONAL) =============
# Only needed if running microservices architecture instead of monolith
API_GATEWAY_PORT=3000
INVENTORY_SERVICE_URL=http://localhost:3001
REQUESTS_SERVICE_URL=http://localhost:3002
REPORTS_SERVICE_URL=http://localhost:3003
