### Step 1: Check Current Status
# Get the laptop and see what the status is right now
GET http://localhost:5000/equipment/1
Accept: application/json

### Step 2: Update the Status
# Change the status to 'under repair'
PUT http://localhost:5000/equipment/1/status
Content-Type: application/json

{
  "status": "available"
}

### Step 3: Verify the Change
# Perform a GET again. If the update worked,
# the status in this response MUST be 'under repair'
GET http://localhost:5000/equipment/1
Accept: application/json